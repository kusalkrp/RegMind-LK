# Database
POSTGRES_URL=postgresql+asyncpg://sltda:changeme@localhost:5432/sltda_mcp

# Vector DB
QDRANT_URL=http://localhost:6333

# AI
GEMINI_API_KEY=your-gemini-api-key-here

# MCP Server
MCP_MAX_CONCURRENCY=15
MCP_TOOL_TIMEOUT_SECONDS=30

# RAG
RAG_TOP_K_CHUNKS=6
RAG_SIMILARITY_THRESHOLD=0.60
RAG_MAX_CONTEXT_TOKENS=2500
RAG_MAX_SYNTHESIS_TOKENS=600

# Ingestion
INGESTION_RATE_LIMIT_RPS=1.0
INGESTION_MIN_FILE_SIZE_KB=5
INGESTION_PARSE_FAILURE_ABORT_THRESHOLD=0.10

# Observability
LOG_LEVEL=INFO
REFRESH_NOTIFY_SLACK_WEBHOOK=

# Document storage (relative to project root)
DOCUMENTS_BASE_PATH=./documents
